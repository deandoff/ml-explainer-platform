# Database
POSTGRES_USER=mlexplainer
POSTGRES_PASSWORD=changeme
POSTGRES_DB=mlexplainer
DATABASE_URL=postgresql://mlexplainer:changeme@postgres:5432/mlexplainer

# Redis
REDIS_URL=redis://redis:6379/0

# Storage mode: "local" or "s3"
STORAGE_MODE=local

# Local Storage (used when STORAGE_MODE=local)
LOCAL_STORAGE_PATH=./storage

# Yandex Object Storage (only needed when STORAGE_MODE=s3)
# S3_ENDPOINT_URL=https://storage.yandexcloud.net
# S3_ACCESS_KEY_ID=your_access_key
# S3_SECRET_ACCESS_KEY=your_secret_key
# S3_BUCKET_NAME=ml-explainer-artifacts
# S3_REGION=ru-central1

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
SECRET_KEY=your-secret-key-change-in-production

# Frontend
REACT_APP_API_URL=http://localhost:8000

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Environment
ENVIRONMENT=development
